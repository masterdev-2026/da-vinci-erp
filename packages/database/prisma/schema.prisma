generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================
// CORE MULTI-TENANT
// ========================

model Company {
  id        String   @id @default(uuid())
  name      String
  document  String?  @unique
  createdAt DateTime @default(now())

  users             User[]
  roles             Role[]
  financialAccounts FinancialAccount[]
  transactions      Transaction[]
  categories        Category[]

  drivers   Driver[]
  licenses  License[]
  contracts Contract[]

  customers Customer[]
  suppliers Supplier[]
  banks     Bank[]

  serviceOrders ServiceOrder[]
  partners      Partner[]
  networkLinks  NetworkLink[]

  vehicles     Vehicle[]
  maintenances Maintenance[]
  fuelLogs     FuelLog[]
  fines        Fine[]
  inspections  Inspection[]

  employees     Employee[]
  positions     Position[]
  admissions    Admission[]
  terminations  Termination[]
  salaryHistory SalaryHistory[]

  timeRecords          TimeRecord[]
  overtimeBanks        OvertimeBank[]
  vacations            Vacation[]
  leaves               Leave[]
  requests             Request[]
  equipments           Equipment[]
  equipmentAssignments EquipmentAssignment[]
  jobOpenings          JobOpening[]
  candidates           Candidate[]
  applications         Application[]
  payrolls             Payroll[]
  auditLogs AuditLog[]

  @@index([name])
}

// ========================
// CADASTROS
// ========================

model Customer {
  id       String  @id @default(uuid())
  name     String
  document String?
  email    String?
  phone    String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  transactions  Transaction[]
  serviceOrders ServiceOrder[]

  createdAt DateTime @default(now())

  @@index([companyId])
}

model Supplier {
  id       String  @id @default(uuid())
  name     String
  document String?
  email    String?
  phone    String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  transactions Transaction[]

  createdAt DateTime @default(now())

  @@index([companyId])
}

model Bank {
  id   String @id @default(uuid())
  name String
  code String

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  accounts FinancialAccount[]

  createdAt DateTime @default(now())

  @@unique([code, companyId])
}

// ========================
// USUÁRIOS
// ========================

model User {
  id       String  @id @default(uuid())
  name     String
  email    String  @unique
  password String
  isActive Boolean @default(true)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  roles UserRole[]
  auditLogs AuditLog[]

  createdAt DateTime @default(now())
}

// ========================
// RBAC
// ========================

model Role {
  id   String @id @default(uuid())
  name String

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  permissions Permission[]
  users       UserRole[]
}

model Permission {
  id   String @id @default(uuid())
  name String

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id])
  role Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
}

// ========================
// ADMINISTRATIVO
// ========================

model Driver {
  id       String  @id @default(uuid())
  name     String
  document String
  license  String
  phone    String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  licenses  License[]
  contracts Contract[]

  createdAt DateTime @default(now())

  @@unique([document, companyId])
}

model License {
  id        String      @id @default(uuid())
  type      LicenseType
  number    String
  expiresAt DateTime

  driverId String
  driver   Driver @relation(fields: [driverId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id])
}

// ========================
// CONTRATOS
// ========================

model Contract {
  id     String  @id @default(uuid())
  title  String
  amount Decimal

  startDate DateTime
  endDate   DateTime?

  recurrence RecurrenceType

  driverId String
  driver   Driver @relation(fields: [driverId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
}

// ========================
// LOGÍSTICA
// ========================

model ServiceOrder {
  id     String             @id @default(uuid())
  code   String             @unique
  title  String
  status ServiceOrderStatus @default(OPEN)
  value  Decimal

  scheduledAt DateTime?
  startedAt   DateTime?
  finishedAt  DateTime?

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  partnerId String?
  partner   Partner? @relation(fields: [partnerId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id])
}

model Partner {
  id   String @id @default(uuid())
  name String

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  serviceOrders ServiceOrder[]
  NetworkLink   NetworkLink[]
}

model NetworkLink {
  id String @id @default(uuid())

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  partnerId String
  partner   Partner @relation(fields: [partnerId], references: [id])

  status NetworkStatus @default(ACTIVE)
}

// ========================
// RECURSOS HUMANOS
// ========================

model Employee {
  id       String  @id @default(uuid())
  name     String
  document String
  email    String?
  phone    String?

  positionId String
  position   Position @relation(fields: [positionId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  status EmployeeStatus @default(ACTIVE)

  admissions   Admission[]
  terminations Termination[]
  salaries     SalaryHistory[]

  timeRecords          TimeRecord[]
  overtimeBanks        OvertimeBank[]
  vacations            Vacation[]
  leaves               Leave[]
  requests             Request[]
  equipmentAssignments EquipmentAssignment[]
  payrolls             Payroll[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
}

model Position {
  id   String @id @default(uuid())
  name String

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  employees Employee[]

  createdAt DateTime @default(now())
}

model Admission {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  date   DateTime
  salary Float

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
}

model Termination {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  date   DateTime
  reason String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
}

model SalaryHistory {
  id         String   @id @default(uuid())
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  salary Float
  date   DateTime

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
}

model TimeRecord {
  id String @id @default(uuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  type TimeRecordType

  timestamp DateTime

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())

  @@index([employeeId])
  @@index([companyId])
}

model OvertimeBank {
  id String @id @default(uuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  minutes Int

  type OvertimeType

  referenceDate DateTime

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())

  @@index([employeeId])
  @@index([companyId])
}

model Vacation {
  id String @id @default(uuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  startDate DateTime
  endDate   DateTime

  status VacationStatus @default(PENDING)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())

  @@index([employeeId])
  @@index([companyId])
}

model Leave {
  id String @id @default(uuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  type LeaveType

  startDate DateTime
  endDate   DateTime?

  reason String?

  status LeaveStatus @default(PENDING)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())

  @@index([employeeId])
  @@index([companyId])
}

model Request {
  id String @id @default(uuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  type RequestType

  title       String
  description String?

  status RequestStatus @default(PENDING)

  response String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([employeeId])
  @@index([companyId])
}

model Equipment {
  id String @id @default(uuid())

  name        String
  description String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  assignments EquipmentAssignment[]

  createdAt DateTime @default(now())

  @@index([companyId])
}

model EquipmentAssignment {
  id String @id @default(uuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id])

  deliveredAt DateTime
  returnedAt  DateTime?

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())

  @@index([employeeId])
  @@index([companyId])
}

model JobOpening {
  id String @id @default(uuid())

  title       String
  description String?

  status JobStatus @default(OPEN)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  applications Application[]

  createdAt DateTime @default(now())

  @@index([companyId])
}

model Candidate {
  id String @id @default(uuid())

  name  String
  email String?
  phone String?

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  applications Application[]

  createdAt DateTime @default(now())

  @@index([companyId])
}

model Application {
  id String @id @default(uuid())

  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id])

  jobId String
  job   JobOpening @relation(fields: [jobId], references: [id])

  status ApplicationStatus @default(APPLIED)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())

  @@index([companyId])
}

model Payroll {
  id String @id @default(uuid())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id])

  referenceMonth Int
  referenceYear  Int

  baseSalary Float
  netSalary  Float

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  items PayrollItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, referenceMonth, referenceYear, companyId])
  @@index([employeeId])
  @@index([companyId])
}

model PayrollItem {
  id String @id @default(uuid())

  payrollId String
  payroll   Payroll @relation(fields: [payrollId], references: [id])

  description String
  amount      Float

  type PayrollItemType

  createdAt DateTime @default(now())
}

model AuditLog {
  id String @id @default(uuid())

  userId String?
  user   User? @relation(fields: [userId], references: [id])

  action String
  entity String
  entityId String?

  data Json?

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([userId])
}

// ========================
// GESTÃO DE FROTAS
// ========================

model Vehicle {
  id    String @id @default(uuid())
  plate String
  model String
  brand String
  year  Int

  status VehicleStatus @default(ACTIVE)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  maintenances Maintenance[]
  fuelLogs     FuelLog[]
  fines        Fine[]
  inspections  Inspection[]

  createdAt DateTime @default(now())

  @@unique([plate, companyId])
}

model Maintenance {
  id          String            @id @default(uuid())
  type        MaintenanceType
  description String
  cost        Decimal           @default(0)
  status      MaintenanceStatus @default(PENDING)

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([vehicleId])
}

model FuelLog {
  id         String  @id @default(uuid())
  liters     Float
  price      Decimal
  km         Float
  kmPerLiter Float?

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())

  @@index([vehicleId])
  @@index([companyId])
}

model Fine {
  id          String     @id @default(uuid())
  code        String
  description String
  amount      Decimal
  status      FineStatus @default(PENDING)

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())

  @@index([vehicleId])
  @@index([companyId])
}

model Inspection {
  id    String  @id @default(uuid())
  notes String?

  items Json?

  status InspectionStatus @default(PENDING)

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())

  @@index([vehicleId])
  @@index([companyId])
}

// ========================
// FINANCEIRO
// ========================

model Category {
  id   String          @id @default(uuid())
  name String
  type TransactionType

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  transactions Transaction[]
}

model FinancialAccount {
  id      String  @id @default(uuid())
  name    String
  balance Decimal @default(0)

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  transactions Transaction[]
  Bank         Bank?         @relation(fields: [bankId], references: [id])
  bankId       String?
}

model Transaction {
  id     String            @id @default(uuid())
  title  String
  amount Decimal
  type   TransactionType
  status TransactionStatus @default(PENDING)

  dueDate DateTime
  paidAt  DateTime?

  // RELAÇÕES OBRIGATÓRIAS
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  accountId String
  account   FinancialAccount @relation(fields: [accountId], references: [id])

  // RELAÇÕES OPCIONAIS (CORRIGE SEU ERRO)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  createdAt DateTime @default(now())

  @@index([companyId])
  @@index([categoryId])
}

// ========================
// ENUMS
// ========================

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionStatus {
  PENDING
  PAID
  OVERDUE
}

enum LicenseType {
  CNH
  ANTT
  OTHER
}

enum RecurrenceType {
  MONTHLY
}

enum ServiceOrderStatus {
  OPEN
  IN_PROGRESS
  DONE
}

enum NetworkStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

enum VehicleStatus {
  ACTIVE
  INACTIVE
}

enum MaintenanceType {
  PREVENTIVE
  CORRECTIVE
}

enum MaintenanceStatus {
  PENDING
  COMPLETED
}

enum FineStatus {
  PENDING
  PAID
}

enum InspectionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
}

enum TimeRecordType {
  CLOCK_IN
  CLOCK_OUT
}

enum OvertimeType {
  CREDIT
  DEBIT
}

enum VacationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum LeaveType {
  MEDICAL
  MATERNITY
  ACCIDENT
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RequestType {
  VACATION
  LEAVE
  ADVANCE
  SHIFT_CHANGE
  OTHER
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum JobStatus {
  OPEN
  CLOSED
}

enum ApplicationStatus {
  APPLIED
  INTERVIEW
  APPROVED
  REJECTED
}

enum PayrollStatus {
  PENDING
  CLOSED
}

enum PayrollItemType {
  EARNING
  DEDUCTION
}
